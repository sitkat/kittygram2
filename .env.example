# Django settings
# Секретный ключ Django — используется для криптографических подписей.
# Сгенерируйте уникальный ключ: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Режим отладки: True — для разработки, False — для продакшена.
DEBUG=True

# Список разрешённых хостов через запятую.
# Пример: localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1
